BINANCE_API_KEY=your_key
BINANCE_API_SECRET=your_secret
# Default cloud image used by docker-compose.yml
TRADE_OPS_IMAGE=ghcr.io/naoufalelbani/trade-ops-sentinel-freqtrade:v0.2.6

TELEGRAM_BOT_TOKEN=123456:your_bot_token
TELEGRAM_CHAT_ID=123456789
# Optional image/build metadata (shown by /version and startup logs)
APP_VERSION=v0.2.6
APP_COMMIT=local
APP_BUILD_DATE=2026-03-08T00:00:00Z

SYMBOL=BNBUSDT
# Use comma-separated symbols, ALL, or FREQTRADE.
TRACKED_SYMBOLS=BNBUSDT,BTCUSDT,ETHUSDT
MAX_AUTO_TRACKED_SYMBOLS=40
BNB_ASSET=BNB
QUOTE_ASSET=USDT
FREQTRADE_API_URL=http://freqtrade:8080
FREQTRADE_USERNAME=freqtrade
FREQTRADE_PASSWORD=change_me
FREQTRADE_TRADES_LIMIT=500
FREQTRADE_MAX_PAGES=20

# MIN_BNB_THRESHOLD=0.03
# TARGET_BNB=0.06

# Optional: use quote-based thresholds instead of BNB values.
# If these are set (>0), bot auto-converts by live BNB price.
MIN_BNB_THRESHOLD_USDT=0.5
TARGET_BNB_USDT=2

# Optional: use ratio mode (percentage of total portfolio value in BNB).
# Enable this to keep BNB around a percentage of your balance.
# Example below means min 0.15%, target 0.20%.
# BNB_RATIO_MODE=true
# BNB_RATIO_MIN=0.0015
# BNB_RATIO_TARGET=0.0020

MAX_BUY_QUOTE=2
MIN_BUY_QUOTE=1

CHECK_INTERVAL=2m
BUY_COOLDOWN=15m
RECV_WINDOW_MS=5000
SUMMARY_EVERY_CHECKS=10
NOTIFY_ON_EVERY_CHECK=false

ACCOUNT_RESERVE_RATIO=0.98
BINANCE_BASE_URL=https://api.binance.com
TELEGRAM_BASE_URL=https://api.telegram.org

STATE_FILE=./data/state.json
MAX_SNAPSHOTS=3000

DAILY_REPORT_ENABLED=true
DAILY_REPORT_TIME_UTC=00:05
DAILY_REPORT_TIMEZONE=UTC
DAILY_REPORT_MODE=full
DAILY_DIGEST_TRADES=3
FEE_MAIN_CURRENCY=BNB

HEARTBEAT_ENABLED=true
HEARTBEAT_ALERT_ENABLED=true
HEARTBEAT_STALE_AFTER=10m
HEARTBEAT_CHECK_INTERVAL=1m
# Optional external heartbeat endpoint (e.g. healthchecks.io ping URL)
HEARTBEAT_PING_URL=

API_FAILURE_ALERT_ENABLED=true
API_FAILURE_THRESHOLD=3
API_FAILURE_ALERT_COOLDOWN=15m
API_LATENCY_THRESHOLD=8s
API_LATENCY_SPIKE_THRESHOLD=3

ABNORMAL_MOVE_ALERT_ENABLED=true
ABNORMAL_MOVE_DROP_1H_PCT=3
ABNORMAL_MOVE_DROP_24H_PCT=8
ABNORMAL_MOVE_ALERT_COOLDOWN=2h

REDIS_ENABLED=false
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TRADE_TTL=10m
REDIS_PRICES_TTL=15s
REDIS_KEY_PREFIX=bnbfm:

MYTRADES_MAX_CONCURRENCY=1
MYTRADES_MIN_INTERVAL=400ms

SQLITE_ENABLED=false
SQLITE_PATH=./data/trades.db
SQLITE_INITIAL_LOOKBACK_DAYS=7
SQLITE_SYNC_INTERVAL=5m
SQLITE_MAX_LOOKBACK_DAYS=30
